NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Configure social sign-in providers in the Clerk Dashboard:
# Google, Apple, Microsoft, GitHub, and email are recommended for MVP.

# Stripe Checkout subscriptions. Stripe can show Apple Pay / Google Pay in hosted Checkout
# when payment methods are enabled, the app is served over HTTPS, and the domain is registered.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# Canonical app URL for metadata, robots/sitemap, and Stripe return URLs.
# For production Vercel, use your deployed app URL, not the Supabase project URL.
NEXT_PUBLIC_APP_URL=https://card-forge-snowy.vercel.app
STRIPE_WEBHOOK_SECRET=

# Optional entitlement allowlists while billing is not connected.
# These unlock clean exports for signed-in Clerk accounts only.
CARDFORGE_PAID_ACCOUNT_EMAILS=
CARDFORGE_DEV_ACCOUNT_EMAILS=
CARDFORGE_OWNER_ACCOUNT_EMAILS=

# Optional reusable QA accounts for authenticated smoke tests.
# Prefer these over disposable Clerk users so local/dev QA does not leave stray accounts.
# Configure these accounts in Clerk first; the owner account should already have owner/dev access.
CARDFORGE_E2E_FREE_EMAIL=
CARDFORGE_E2E_PAID_EMAIL=
CARDFORGE_E2E_DEV_EMAIL=
CARDFORGE_E2E_OWNER_EMAIL=
# Disposable Clerk users are disabled by default. Set true only when intentionally testing creation/deletion cleanup.
CARDFORGE_E2E_ALLOW_DISPOSABLE_USERS=false

# Optional validation override. Local development defaults to dev; production defaults to free.
NEXT_PUBLIC_CARDFORGE_ACCESS_MODE=
CARDFORGE_ACCESS_MODE=

# Keep false/blank for hosted MVP unless intentionally editing shipped libraries.
CARDFORGE_ALLOW_LIBRARY_WRITES=

# Supabase database for lightweight shared MVP state such as roadmap votes.
# Keep the secret key server-only. Do not expose it in client components.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional later if direct browser Supabase reads are intentionally introduced.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
